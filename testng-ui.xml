<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Playwright UI Suite">
<parameter name="browser" value="chromium"/>

    <test name="Login Module">

        <classes>

            <class name="ui.login.ValidLoginTest"/>
            <class name="ui.login.InvalidLoginTest"/>
            <class name="ui.login.LockedUserTest"/>
            <class name="ui.login.EmptyUsernameTest"/>
            <class name="ui.login.EmptyPasswordTest"/>
            <class name="ui.login.LogoutTest"/>
        <class name="ui.inventory.InventoryValidationTest"/>
        <class name="ui.inventory.ProductCountTest"/>
        <class name="ui.inventory.AddProductTest"/>
        <class name="ui.inventory.RemoveProductTest"/>
         <class name="ui.inventory.ProductSortTest"/>
        </classes>

    </test>

</suite>